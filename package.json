{
  "name": "batiste",
  "version": "0.0.0",
  "private": true,
  "description": "The Autonomous Agent Compute Marketplace — zero-trust MCP infrastructure for routing, billing, auditing, and governing AI agents on your own network.",
  "keywords": [
    "ai-agents",
    "mcp",
    "model-context-protocol",
    "marketplace",
    "zero-trust",
    "cli-tool",
    "automation",
    "developer-experience",
    "productivity",
    "scaffolding",
    "boilerplate",
    "code-generator",
    "templates",
    "audit",
    "kill-switch",
    "llm",
    "llm-infrastructure",
    "typescript",
    "nodejs",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jardhel/batiste"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
