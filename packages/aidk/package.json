{
  "name": "@batiste/aidk",
  "version": "0.1.0",
  "description": "The AI Development Kit — composable building blocks for secure AI agent access to codebases",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./transport": {
      "types": "./dist/re-export-transport.d.ts",
      "import": "./dist/re-export-transport.js"
    },
    "./auth": {
      "types": "./dist/re-export-auth.d.ts",
      "import": "./dist/re-export-auth.js"
    },
    "./scope": {
      "types": "./dist/re-export-scope.d.ts",
      "import": "./dist/re-export-scope.js"
    },
    "./audit": {
      "types": "./dist/re-export-audit.d.ts",
      "import": "./dist/re-export-audit.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@batiste/core": "workspace:*",
    "@batiste/transport": "workspace:*",
    "@batiste/auth": "workspace:*",
    "@batiste/scope": "workspace:*",
    "@batiste/audit": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": { "typescript": "^5.0.0" },
  "keywords": ["ai", "mcp", "aidk", "batiste", "agent"],
  "license": "MIT"
}
