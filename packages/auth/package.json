{
  "name": "@batiste-aidk/auth",
  "version": "0.1.0",
  "description": "Zero-trust authentication for Batiste MCP servers - JWT tokens, scoped API keys, middleware",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/token-issuer.d.ts",
      "import": "./dist/token-issuer.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@batiste-aidk/core": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "jose": "^6.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "ai",
    "mcp",
    "auth",
    "jwt",
    "zero-trust"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jardhel/batiste",
    "directory": "packages/auth"
  }
}
