{
  "name": "@batiste-aidk/transport",
  "version": "0.1.0",
  "description": "Secure gateway transport for Batiste MCP servers - StreamableHTTP, rate limiting, session management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gateway": {
      "types": "./dist/secure-gateway.d.ts",
      "import": "./dist/secure-gateway.js"
    },
    "./sessions": {
      "types": "./dist/session-manager.d.ts",
      "import": "./dist/session-manager.js"
    },
    "./rate-limiter": {
      "types": "./dist/rate-limiter.d.ts",
      "import": "./dist/rate-limiter.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@batiste-aidk/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "ai",
    "mcp",
    "transport",
    "gateway",
    "streamable-http"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jardhel/batiste",
    "directory": "packages/transport"
  }
}
